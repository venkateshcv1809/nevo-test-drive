# ============================================
# Nevo Test Drive - Environment Configuration
# ============================================
# Global vehicle booking system with UTC-first architecture

# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection settings
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_HOST_AUTH_METHOD=

# Database connection URL (used by Prisma)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

# ============================================
# Application Configuration
# ============================================
# API server settings
PORT=
NODE_ENV=

# CORS settings (comma-separated origins)
CORS_ORIGINS=

# ============================================
# Docker Configuration (Optional)
# ============================================
# Container names for Docker Compose
POSTGRES_CONTAINER_NAME=
PGADMIN_CONTAINER_NAME=

# Network configuration
NEVO_NETWORK_NAME=

# Volume configuration
POSTGRES_DATA_VOLUME=

# Port mapping
POSTGRES_EXTERNAL_PORT=
PGADMIN_EXTERNAL_PORT=

# ============================================
# pgAdmin Configuration (Optional)
# ============================================
# Database management interface
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=
PGADMIN_CONFIG_SERVER_MODE=

# ============================================
# Booking Configuration
# ============================================
# Business logic settings
MAX_DATE_SELECTIONS=
BOOKING_DAYS_AHEAD=
TIME_SLOT_DURATION=

# ============================================
# Security Configuration
# ============================================
# JWT settings
JWT_SECRET=
JWT_EXPIRES_IN=

# API rate limiting
RATE_LIMIT_WINDOW_MS=
RATE_LIMIT_MAX_REQUESTS=

# ============================================
# Development/Testing
# ============================================
# Enable debug mode
DEBUG=
